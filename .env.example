# Copy this file to .env and adjust values for your machine.
# Do not commit .env — it may contain secrets.

# PostgreSQL settings used by docker compose (compose.yaml)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=expense_reports
POSTGRES_PORT=5432

# Connection string for the API when running locally with: dotnet run --project ER.WebApi
# Copy this value into appsettings.Development.json or User Secrets (see section 7).
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=expense_reports;Username=postgres;Password=postgres