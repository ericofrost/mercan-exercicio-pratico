{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    },
    "Console": {
      "FormatterName": "json",
      "FormatterOptions": {
        "SingleLine": true,
        "IncludeScopes": true,
        "UseUtcTimestamp": true,
        "JsonWriterOptions": {
          "Indented": false
        }
      }
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=expense_reports;Username=postgres;Password=your_password"
  },
  "Jwt": {
    "Issuer": "ExpenseReports.Api",
    "Audience": "ExpenseReports.Client",
    "Key": "REPLACE_WITH_AT_LEAST_32_CHAR_RANDOM_SECRET_KEY",
    "ExpiryMinutes": 30
  },
  "DatabaseSettings": {
    "DropDatabaseBeforeMigrations": false,
    "SeedSampleData": false
  },
  "LoginRateLimit": {
    "Enabled": true,
    "PermitLimit": 10,
    "WindowSeconds": 60,
    "SegmentsPerWindow": 4
  },
  "AllowedHosts": "*"
}
